// Scenario catalog. v0.2.0 ships one scenario: the Białowieża beech-log
// year-5 saproxylic community. See PROPOSAL-BUG-SIMULATOR.md for the
// reasoning behind picking this as the canonical "hello world."
{
  "tuscan_meadow_summer": {
    "niche_type": "meadow_patch",
    "locality": "Tuscan hillside meadow, central Italy — July afternoon, Mantis religiosa hunting patch",
    "preamble": "A patch of tall grass on a south-facing hillside in central Italy. The sun is high; the grasshoppers are calling; a fresh-molted Mantis religiosa is settled on a stem near the top of the canopy, forelegs cocked, head tracking. Around it, butterflies and honeybees pull nectar from late-summer flowers, grasshoppers crop the grass blades below. The mantis is forty days into its adult life and will not survive autumn; everything below it has a non-trivial chance of being eaten before the mantis itself starves.",
    "meadow_geometry": {
      "height_cm": 60,
      "width_cm": 30,
      "cells_per_height": 30,
      "flower_band_cm": 10,
      "stem_band_cm": 30,
      "soil_band_cm": 3
    },
    "initial_resources": {
      "temperature_C": 26,
      "moisture": 0.45,
      "oxygen": 1.0
    },
    "colonization_pool": {
      "mantis_religiosa":     { "rate_per_day": 0.10, "entry_substrate": "stem",         "max_total": 2,  "step_first": 0 },
      "pieris_brassicae":     { "rate_per_day": 0.7,  "entry_substrate": "flower",       "max_total": 30, "step_first": 0 },
      "apis_mellifera":       { "rate_per_day": 1.2,  "entry_substrate": "flower",       "max_total": 60, "step_first": 0 },
      "chorthippus_brunneus": { "rate_per_day": 0.4,  "entry_substrate": "grass_blade",  "max_total": 20, "step_first": 0 }
    },
    "events": [
      { "step_every": 1, "kind": "meadow_growth", "regrow_nectar": 0.04, "regrow_leaf": 0.03,
        "_note": "Daily plant productivity — flowers refill nectar at 0.04g/day, grass cells regrow leaf biomass at 0.03g/day. Caps at initial values. Models ongoing photosynthesis without modeling plants as Agents." }
    ],
    "duration_steps": 90,
    "step_size_days": 1,
    "source_notes": "European mantis is found throughout central + southern Europe; Tuscan meadows in mid-summer have particularly high prey density (butterflies + honeybees + grasshoppers all active). The cannibalism rate of 30% per mating encounter comes from Lelito & Brown 2006, J Insect Behav. The meadow_growth event represents continuous plant production rather than modeling plants as Agents — the meadow is the niche scaffold, not a participant."
  },
  "cow_dung_european_pasture": {
    "niche_type": "dung_pile",
    "locality": "European pasture — fresh bovine dung pat, mid-summer afternoon",
    "dung_geometry": {
      "diameter_cm": 18,
      "cells_per_diameter": 24,
      "interior_radius_cm": 6.5,
      "soil_interface_radius_cm": 2.0
    },
    "initial_resources": {
      "temperature_C": 24,
      "moisture": 0.85,
      "oxygen": 0.7,
      "ph": 7.0
    },
    "colonization_pool": {
      "aphodius_rufipes":         { "rate_per_day": 1.2,  "entry_substrate": "dung_crust",         "max_total": 40, "step_first": 0  },
      "geotrupes_stercorarius":   { "rate_per_day": 0.35, "entry_substrate": "dung_soil_interface", "max_total": 6,  "step_first": 1, "requires": "dung_g >= 30" },
      "saprinus_semistriatus":    { "rate_per_day": 0.4,  "entry_substrate": "dung_interior",       "max_total": 12, "step_first": 1, "requires": "fly_larvae_density >= 0.3" },
      "beauveria_bassiana":       { "rate_per_day": 0.5,  "entry_substrate": "dung_crust",          "max_total": 15, "step_first": 5, "requires": "bug_corpse_g >= 0.005" }
    },
    "events": [
      { "step_every": 1, "kind": "dung_decay", "rate": 0.06,
        "_note": "Combined microbial decomposition + desiccation. ~6% loss per day of remaining dung_g at 24°C summer pasture conditions. Fly_larvae_density rises mid-stage then falls as substrate dries." }
    ],
    "duration_steps": 30,
    "step_size_days": 1,
    "source_notes": "Dung beetles are among the most-studied coprophage communities (Hanski & Cambefort 1991). Three roles: dwellers (Aphodius — surface feeding), tunnelers (Geotrupes — moves substrate vertically into soil), and predators (Saprinus — fly larvae). The three roles partition the substrate temporally + spatially; without any one of them the pat lingers longer (Lumaret 1990). Modeled here over a 30-day window so the visible-life of the pat completes plus a tail of late-stage attrition.",
    "preamble": "Mid-summer European pasture. A cow has deposited 1.8 kg of fresh dung on the grass an hour ago. Crust is just starting to form; the interior is still moist and warm with the host's body heat. The volatiles broadcast over the next few hours will draw most of the regional dung-beetle population. Two weeks from now the pat will be visibly diminished; in a month it will be a flat disc of fibre and the soil beneath will be incorporating its nitrogen into the next year's grass."
  },
  "carcass_temperate_woodland": {
    "niche_type": "carrion",
    "locality": "Knoxville Anthropology Research Facility analog — 1.5 kg small-mammal carcass, summer temperate woodland",
    "carrion_geometry": {
      "long_axis_cm": 30,
      "short_axis_cm": 14,
      "cells_per_long_axis": 30,
      "skin_thickness_cm": 1.2
    },
    "initial_resources": {
      "temperature_C": 19,
      "moisture": 0.7,
      "oxygen": 0.7,
      "ph": 6.5
    },
    "colonization_pool": {
      "calliphora_vicina":   { "rate_per_day": 0.8, "entry_substrate": "soft_tissue", "max_total": 50, "step_first": 1,  "requires": "soft_tissue_g >= 50" },
      "necrodes_littoralis": { "rate_per_day": 0.4, "entry_substrate": "soft_tissue", "max_total": 6,  "step_first": 5,  "requires": "soft_tissue_g >= 30" },
      "dermestes_lardarius": { "rate_per_day": 0.3, "entry_substrate": "skin",        "max_total": 8,  "step_first": 18, "requires": "soft_tissue_g <= 60" },
      "beauveria_bassiana":  { "rate_per_day": 0.4, "entry_substrate": "soft_tissue", "max_total": 20, "step_first": 8, "requires": "bug_corpse_g >= 0.005" }
    },
    "events": [
      { "step_every": 1, "kind": "carrion_decay", "rate": 0.02,
        "_note": "Daily bacterial + abiotic decay rate (independent of insect consumption). 2% of remaining soft_tissue per day at 19°C." }
    ],
    "duration_steps": 90,
    "step_size_days": 1,
    "source_notes": "The canonical example of biological succession in forensic entomology. Three waves: blowflies first (fresh + bloat stages, day 1-10), then large carrion beetles (active decay, ~day 5-25, which both consume soft tissue and predate fly larvae), then larder beetles (advanced decay through dry remains, day 20+). The simulator's per-day carrion_decay event represents the baseline bacterial decomposition independent of insect activity. Goff 2009, Byrd & Castner 2009 are the canonical references.",
    "preamble": "A 1.5 kg small mammal has died at the edge of temperate woodland on a summer morning. The body is fresh, the temperature is 19 °C, and the volatile organic compounds released over the next few hours will draw blowflies from up to a kilometre away. Decomposition will run through five recognised stages over the next ninety days. The bug community that exploits each stage is the surveyor's record of when the death occurred."
  },
  "sarracenia_purpurea_cedar_bog": {
    "niche_type": "phytotelma",
    "locality": "Cedar Bog, southern Ontario — Sarracenia purpurea pitcher, mid-summer",
    "pitcher_geometry": {
      "pitcher_height_cm": 12,
      "top_radius_cm": 3.5,
      "floor_radius_cm": 1.0,
      "water_level_cm": 5.0,
      "lip_band_cm": 0.6,
      "cells_per_height": 36
    },
    "initial_resources": {
      "temperature_C": 18,
      "moisture": 0.7,
      "oxygen": 0.8,
      "ph": 5.0
    },
    "colonization_pool": {
      "sarracenia_purpurea":   { "rate_per_day": 1.0,  "entry_substrate": "pitcher_floor", "max_total": 1,  "step_first": 0  },
      "habrotrocha_rosa":      { "rate_per_day": 0.30, "entry_substrate": "pitcher_floor", "max_total": 12, "step_first": 3,  "requires": "prey_detritus_g >= 0.5" },
      "metriocnemus_knabi":    { "rate_per_day": 0.25, "entry_substrate": "pitcher_floor", "max_total": 18, "step_first": 5,  "requires": "prey_detritus_g >= 1.0" },
      "wyeomyia_smithii":      { "rate_per_day": 0.40, "entry_substrate": "water_column",  "max_total": 30, "step_first": 7,  "requires": "bacterial_biomass_g >= 0.2" }
    },
    "events": [
      { "step_every": 1,  "kind": "prey_capture",  "amount_g": 0.15, "substrate": "pitcher_floor",
        "_note": "Sarracenia traps a small insect roughly every other day; this is the daily mean intake. Real measured intake at temperate latitudes is 0.05–0.3 g/day depending on weather (Bradshaw & Holzapfel 1989)." }
    ],
    "duration_steps": 90,
    "step_size_days": 1,
    "source_notes": "Pitcher-plant phytotelmata are the canonical small-aquatic-niche system (Kitching 2000). Cedar Bog in southern Ontario is a well-studied site near the northern edge of Sarracenia purpurea's range. Daily prey-capture flux comes from Bradshaw & Holzapfel 1989; the three-species inquiline community (Wyeomyia + Metriocnemus + Habrotrocha) is the classic textbook example of a low-diversity, well-bounded food web. Sarracenia itself is modeled as a single sessile colony per niche — the plant doesn't 'eat' in this model; trapped prey becomes detritus that the inquilines process.",
    "preamble": "A purple pitcher plant has opened a new leaf at the edge of a Cedar Bog sphagnum mat. The pitcher holds about thirty millilitres of dilute acidic water in its cup. Insects that crawl in are unable to crawl back out — the wax interior and downward-pointing hairs see to that. The plant absorbs nitrogen and phosphorus from what dissolves; the rest is reconstituted by an inquiline community that lives in the trap fluid year-round."
  },
  "bialowieza_beech_log_y5": {
    "niche_type": "rotting_log",
    "locality": "Białowieża primeval forest, Poland — Fagus sylvatica log, year 5 post-fall",
    "log_geometry": {
      "diameter_cm": 30,
      "bark_thickness_cm": 1.5,
      "sapwood_thickness_cm": 4,
      "heartwood_thickness_cm": 8,
      "pith_radius_cm": 1.5,
      "cells_per_diameter": 30
    },
    "initial_resources": {
      "temperature_C": 14,
      "moisture": 0.55,
      "oxygen": 0.85,
      "ph": 5.5
    },
    "colonization_pool": {
      "trametes_versicolor":        { "rate_per_day": 0.20, "entry_substrate": "sapwood",   "max_total": 12, "step_first": 1  },
      "ceratophysella_denticulata": { "rate_per_day": 0.50, "entry_substrate": "sapwood",   "max_total": 80, "step_first": 10, "requires": "fungal_biomass_g >= 0.5" },
      "glomeris_marginata":         { "rate_per_day": 0.10, "entry_substrate": "bark",      "max_total": 8,  "step_first": 5  },
      "oniscus_asellus":            { "rate_per_day": 0.12, "entry_substrate": "bark",      "max_total": 10, "step_first": 8  },
      "neobisium_muscorum":         { "rate_per_day": 0.08, "entry_substrate": "bark",      "max_total": 5,  "step_first": 30, "requires": "fungal_biomass_g >= 0.5" },
      "lithobius_forficatus":       { "rate_per_day": 0.05, "entry_substrate": "bark",      "max_total": 3,  "step_first": 25, "requires": "fungal_biomass_g >= 1.0" },
      "beauveria_bassiana":         { "rate_per_day": 0.3,  "entry_substrate": "bark",      "max_total": 12, "step_first": 30, "requires": "bug_corpse_g >= 0.005" }
    },
    "duration_steps": 120,
    "step_size_days": 1,
    "source_notes": "The four-species core is the smallest saproxylic trophic chain that exercises every engine seam (sessile grow, three agent tickers, predator-prey, colonization). Białowieża primeval forest is one of the most-studied European saproxylic localities (Speight 1989; Stokland, Siitonen, Jonsson 2012). The Trametes -> Glomeris/Ceratophysella -> Lithobius chain is regionally typical for beech logs at year 5 (advanced sapwood decay, surface bracket fungi establishing). Species-level locality verification against the published Białowieża inventory is pending — see species.json _audit_note_v0_2_0.",
    "preamble": "A fallen beech log in the primeval forest of Białowieża, five years after the tree came down. The sapwood is partly decayed and humid; bark is starting to slough; turkey-tail fungus has established on the south side and the wood inside the bracket-occupied zone is being slowly converted to fungal biomass. A saproxylic community is in the process of arriving. Most of what colonizes a log year-five is doing so because the year-one community pre-conditioned the substrate."
  }
}
